{
  "name": "impulse/swoole-app",
  "description": "Application",
  "type": "project",
  "require": {
    "php": ">=8.3",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*",
    "ext-phalcon": "^5.0",
    "ext-swoole": "*",
    "vlucas/phpdotenv": "^5.5"
  },
  "require-dev": {
    "swoole/ide-helper": "^6.0",
    "phalcon/ide-stubs": "^5.8.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
